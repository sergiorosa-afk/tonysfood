# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
DATABASE_URL="mysql://usuario:senha@host:3306/tonysfood_db"

# ──────────────────────────────────────────────
# Auth (NextAuth.js)
# ──────────────────────────────────────────────
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ──────────────────────────────────────────────
# AI — Anthropic Claude
# If not set, the system falls back to MockProvider (regex-based)
# ──────────────────────────────────────────────
ANTHROPIC_API_KEY=""

# ──────────────────────────────────────────────
# WhatsApp Business API (Meta)
# ──────────────────────────────────────────────
# WHATSAPP_VERIFY_TOKEN and phone_number_id are stored per-unit
# in the Integration table — configure via /integracoes/whatsapp

# ──────────────────────────────────────────────
# Webhooks (outbound)
# Secret is stored per-webhook in the Webhook table
# Signatures use HMAC-SHA256 via X-Signature header
# ──────────────────────────────────────────────

# ──────────────────────────────────────────────
# App
# ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
